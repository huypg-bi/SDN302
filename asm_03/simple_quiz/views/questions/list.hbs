<h2 class="mb-3">Questions</h2>
<div class="mb-4">
    <a href="/questions/create" class="btn btn-primary">Create New Question</a>
</div>

{{#if questions.length}}
    {{#each questions}}
        <div class="d-flex justify-content-between align-items-center border p-3 mb-2">
            <a href="/questions/{{this._id}}">{{this.text}}</a>
            <form action="/questions/{{this._id}}?_method=DELETE" method="POST"
                onsubmit="return confirm('Bạn chắc chắn muốn xóa?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
        </div>
    {{/each}}
{{else}}
    <p class="text-muted">No questions were created.</p>
{{/if}}
