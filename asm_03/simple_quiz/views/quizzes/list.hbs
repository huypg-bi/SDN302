<h2 class="mb-3">Quizzes</h2>
<div class="mb-4">
    <a href="/quizzes/create" class="btn btn-primary">Create New Quiz</a>
</div>

{{#if quizzes.length}}
    {{#each quizzes}}
        <div class="d-flex justify-content-between align-items-center border p-3 mb-2">
            <a href="/quizzes/{{this._id}}/details" class="text-decoration-none text-dark">{{this.title}}</a>
            <form action="/quizzes/{{this._id}}?_method=DELETE" method="POST"
                onsubmit="return confirm('Bạn chắc chắn muốn xóa?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
        </div>
    {{/each}}
{{else}}
    <p class="text-muted">No quizzes were created.</p>
{{/if}}
